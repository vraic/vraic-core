<% content_for :title, "Locations" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Locations</h1>
    <%= link_to "New location", new_location_path, class: primary_button_class %>
  </div>

  <div class="mt-8 <%= table_container_class %>">
    <table class="<%= table_class %>">
      <thead class="<%= thead_class %>">
        <tr>
          <th class="<%= th_class %>">Name</th>
        </tr>
      </thead>
      <tbody class="<%= tbody_class %>" id="locations">
        <% if @locations.any? %>
          <% @locations.each do |location| %>
            <tr class="<%= tr_class %>">
              <td class="<%= td_class %>">
                <%= link_to location.name, location, class: "text-indigo-600 hover:text-indigo-900 font-semibold" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td class="<%= td_class %> text-center py-10">No locations found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
