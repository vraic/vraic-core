<% content_for :title, "Suppliers" %>

<div class="w-full">
  
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Suppliers</h1>
    <div class="space-x-2">
      <%= link_to "Requests", supplier_requests_path, class: secondary_button_class %>
      <%= link_to "New supplier", new_supplier_path, class: primary_button_class %>
    </div>
  </div>

  <div class="mt-8">
    <%= form_with url: suppliers_path, method: :get, class: "flex gap-2", id: "supplier-search-form" do |f| %>
      <div class="grow">
        <%= f.text_field :query, value: params[:query], placeholder: "Search suppliers by name, email or phone...", class: input_class %>
      </div>
      <%= f.submit "Search", class: secondary_button_class %>
      <%= link_to "Clear", suppliers_path, class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" if params[:query].present? %>
    <% end %>
  </div>

  <div class="mt-8 <%= table_container_class %>">
    <table class="<%= table_class %>">
      <thead class="<%= thead_class %>">
        <tr>
          <% if Current.account.nil? && Current.user&.admin? %>
            <th class="<%= th_class %>">Account</th>
          <% end %>
          <th class="<%= th_class %>">Supplier</th>
          <th class="<%= th_class %>">Email</th>
          <th class="<%= th_class %>">Phone</th>
          <th class="<%= th_class %>">Actions</th>
        </tr>
      </thead>
      <tbody class="<%= tbody_class %>" id="suppliers">
        <% if @suppliers.any? %>
          <% @suppliers.each do |supplier| %>
            <tr class="<%= tr_class %>">
              <% if Current.account.nil? && Current.user&.admin? %>
                <td class="<%= td_class %> font-semibold">
                  <%= supplier.account.name %>
                </td>
              <% end %>
              <td class="<%= td_class %>">
                <%= link_to supplier.name, supplier, class: "text-indigo-600 hover:text-indigo-900 font-semibold" %>
              </td>
              <td class="<%= td_class %>">
                <%= supplier.email_address %>
              </td>
              <td class="<%= td_class %>">
                <%= supplier.phone %>
              </td>
              <td class="<%= td_class %>">
                <% if supplier.supplier_account_id.present? %>
                  <%= link_to "View Inventory", inventory_supplier_path(supplier), class: "text-indigo-600 hover:text-indigo-900" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="<%= td_class %> text-center py-10">No suppliers found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-8 flex justify-center">
    <%== pagy_tailwind_nav(@pagy) %>
  </div>
</div>
