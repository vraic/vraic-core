<div class="bg-white dark:bg-gray-900">
  <div class="pt-6 pb-16 sm:pb-24">
    <nav aria-label="Breadcrumb" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <div class="flex items-center">
            <%= link_to "Shop", shop_path, class: "mr-4 text-sm font-medium text-gray-900 dark:text-gray-100" %>
            <svg viewBox="0 0 6 20" aria-hidden="true" class="h-5 w-auto text-gray-300">
              <path d="M4.878 4.34H3.551L.27 16.532h1.327l3.281-12.19z" fill="currentColor" />
            </svg>
          </div>
        </li>
        <% if @product.inventory_group %>
        <li>
          <div class="flex items-center">
            <%= link_to @product.inventory_group.name, shop_category_path(@product.inventory_group), class: "mr-4 text-sm font-medium text-gray-900 dark:text-gray-100" %>
            <svg viewBox="0 0 6 20" aria-hidden="true" class="h-5 w-auto text-gray-300">
              <path d="M4.878 4.34H3.551L.27 16.532h1.327l3.281-12.19z" fill="currentColor" />
            </svg>
          </div>
        </li>
        <% end %>

        <li class="text-sm">
          <span aria-current="page" class="font-medium text-gray-500 hover:text-gray-600 dark:text-gray-400"><%= @product.display_name %></span>
        </li>
      </ol>
    </nav>
    <div class="mx-auto mt-8 max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="lg:grid lg:auto-rows-min lg:grid-cols-12 lg:gap-x-8">
        <div class="lg:col-span-5 lg:col-start-8">
          <div class="flex justify-between">
            <h1 class="text-xl font-medium text-gray-900 dark:text-white"><%= @product.display_name %></h1>
            <p class="text-xl font-medium text-gray-900 dark:text-white"><%= humanized_money_with_symbol @product.price %></p>
          </div>
          
          <div class="mt-4">
             <p class="text-sm text-gray-500 dark:text-gray-400">Shop: <%= @product.account.name %></p>
          </div>
        </div>

        <!-- Image gallery -->
        <div class="mt-8 lg:col-span-7 lg:col-start-1 lg:row-span-3 lg:row-start-1 lg:mt-0">
          <h2 class="sr-only">Images</h2>

          <div class="grid grid-cols-1 lg:grid-cols-1 lg:gap-8">
            <% if @product.image.attached? %>
              <%= image_tag @product.image, class: "rounded-lg w-full object-cover" %>
            <% else %>
              <div class="flex h-96 w-full items-center justify-center bg-gray-100 dark:bg-gray-800 rounded-lg">
                 <span class="text-gray-400 text-4xl"><%= @product.name[0] %></span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mt-8 lg:col-span-5">
          <%= form_with url: add_item_cart_path(product_id: @product.id), method: :post, data: { turbo_stream: true } do |f| %>
            <!-- Variant selection could go here if implemented as options -->
            
            <div class="mt-8">
              <div class="flex items-center justify-between">
                <h2 class="text-sm font-medium text-gray-900 dark:text-white">Quantity</h2>
              </div>

              <div class="mt-2">
                <%= f.number_field :quantity, value: 1, min: 1, class: input_class + " w-24" %>
              </div>
            </div>

            <button type="submit" class="mt-8 flex w-full items-center justify-center rounded-md border border-transparent bg-indigo-600 px-8 py-3 text-base font-medium text-white hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:outline-hidden">Add to cart</button>
          <% end %>

          <!-- Product details -->
          <div class="mt-10">
            <h2 class="text-sm font-medium text-gray-900 dark:text-white">Description</h2>

            <div class="mt-4 space-y-4 text-sm/6 text-gray-500 dark:text-gray-400">
              <%= simple_format @product.description %>
            </div>
          </div>

          <% if @variants.any? %>
          <div class="mt-8 border-t border-gray-200 pt-8 dark:border-gray-700">
            <h2 class="text-sm font-medium text-gray-900 dark:text-white">Variants</h2>

            <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <% @variants.each do |variant| %>
                <%= link_to shop_product_path(variant), class: "relative flex items-center space-x-3 rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm focus-within:ring-2 focus-within:ring-indigo-500 focus-within:ring-offset-2 hover:border-gray-400 dark:bg-gray-800 dark:border-gray-700" do %>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 dark:text-white"><%= variant.variant_label %></p>
                    <p class="text-sm text-gray-500 truncate dark:text-gray-400"><%= humanized_money_with_symbol variant.price %></p>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
          <% end %>

          <!-- Policies (Optional but part of template) -->
          <section aria-labelledby="policies-heading" class="mt-10">
            <h2 id="policies-heading" class="sr-only">Our Policies</h2>

            <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
              <div class="rounded-lg border border-gray-200 bg-gray-50 p-6 text-center dark:bg-gray-800 dark:border-gray-700">
                <dt>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="mx-auto size-6 shrink-0 text-gray-400">
                    <path d="m6.115 5.19.319 1.913A6 6 0 0 0 8.11 10.36L9.75 12l-.387.775c-.217.433-.132.956.21 1.298l1.348 1.348c.21.21.329.497.329.795v1.089c0 .426.24.815.622 1.006l.153.076c.433.217.956.132 1.298-.21l.723-.723a8.7 8.7 0 0 0 2.288-4.042 1.087 1.087 0 0 0-.358-1.099l-1.33-1.108c-.251-.21-.582-.299-.905-.245l-1.17.195a1.125 1.125 0 0 1-.98-.314l-.295-.295a1.125 1.125 0 0 1 0-1.591l.13-.132a1.125 1.125 0 0 1 1.3-.21l.603.302a.809.809 0 0 0 1.086-1.086L14.25 7.5l1.256-.837a4.5 4.5 0 0 0 1.528-1.732l.146-.292M6.115 5.19A9 9 0 1 0 17.18 4.64M6.115 5.19A8.965 8.965 0 0 1 12 3c1.929 0 3.716.607 5.18 1.64" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span class="mt-4 text-sm font-medium text-gray-900 dark:text-white">Local collection</span>
                </dt>
                <dd class="mt-1 text-sm text-gray-500 dark:text-gray-400">Collect from your chosen point</dd>
              </div>
              <div class="rounded-lg border border-gray-200 bg-gray-50 p-6 text-center dark:bg-gray-800 dark:border-gray-700">
                <dt>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="mx-auto size-6 shrink-0 text-gray-400">
                    <path d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span class="mt-4 text-sm font-medium text-gray-900 dark:text-white">Loyalty rewards</span>
                </dt>
                <dd class="mt-1 text-sm text-gray-500 dark:text-gray-400">Earn points on every purchase</dd>
              </div>
            </dl>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>
