<div class="sm:mx-auto sm:w-full sm:max-w-md">
  <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 dark:text-white">
    Two-Factor Verification
  </h2>
  <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
    <% if @user.otp_enabled? %>
      Please enter the code from your authenticator app.
    <% else %>
      We've sent a verification code to your email address.
    <% end %>
  </p>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
  <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 dark:bg-gray-800">
    <%= form_with url: two_factor_verification_path, method: :post, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :otp_code, "Verification Code", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <div class="mt-1">
          <%= f.text_field :otp_code, autofocus: true, autocomplete: "one-time-code", inputmode: "numeric", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm dark:bg-gray-700 dark:border-gray-600 dark:text-white", required: true %>
        </div>
      </div>

      <div>
        <%= f.submit "Verify", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= link_to "Back to Login", new_session_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400" %>
    </div>
  </div>
</div>
