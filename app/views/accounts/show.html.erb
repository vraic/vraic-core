<% content_for :title, "Showing account" %>

<div class="w-full">
  
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-4xl">Showing account</h1>
    <div class="flex gap-2">
      <%= link_to "Audit Log", audits_account_path(@account), class: secondary_button_class %>
      <%= link_to "Edit this account", edit_account_path(@account), class: secondary_button_class %>
    </div>
  </div>

  <div class="md:w-2/3 w-full mb-8">
    <%= render @account %>
  </div>

  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold">Staff & Permissions</h2>
      <% if policy(AccountUser.new(account: @account)).create? %>
        <%= link_to "Add User", new_account_account_user_path(@account), class: primary_button_class %>
      <% end %>
    </div>

    <div class="<%= table_container_class %>">
      <table class="<%= table_class %>">
        <thead class="<%= thead_class %>">
          <tr>
            <th class="<%= th_class %>">Name</th>
            <th class="<%= th_class %>">Email</th>
            <th class="<%= th_class %>">Role</th>
            <th class="<%= th_class %>">Actions</th>
          </tr>
        </thead>
        <tbody class="<%= tbody_class %>">
          <% @account_users.each do |account_user| %>
            <tr id="<%= dom_id account_user %>">
              <td class="<%= td_class %>"><%= account_user.user.name %></td>
              <td class="<%= td_class %>"><%= account_user.user.email_address %></td>
              <td class="<%= td_class %>">
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= account_user.store_manager? ? 'bg-purple-50 text-purple-700 ring-purple-700/10' : 'bg-blue-50 text-blue-700 ring-blue-700/10' %>">
                  <%= account_user.user_role.titleize %>
                </span>
              </td>
              <td class="<%= td_class %>">
                <div class="flex gap-4">
                  <% if policy(account_user).edit? %>
                    <%= link_to "Edit", edit_account_user_path(account_user), class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" %>
                  <% end %>
                  <% if policy(account_user).destroy? %>
                    <%= button_to "Remove", account_user_path(account_user), method: :delete, class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300", data: { turbo_confirm: "Are you sure?" } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="flex flex-wrap gap-2 mt-8 border-t pt-8">
    <%= link_to "Back to accounts", accounts_path, class: secondary_button_class("w-full sm:w-auto text-center") %>
    <% if policy(@account).destroy? %>
      <%= button_to "Destroy this account", @account, method: :delete, form_class: "w-full sm:w-auto", class: danger_button_class("w-full"), data: { turbo_confirm: "Are you sure?" } %>
    <% end %>
  </div>
</div>
