<% content_for :no_sidebar, true %>
<% content_for :title, "New account" %>

<div class="w-full">
  <h1 class="font-bold text-4xl mb-6">New account</h1>

  <div class="border-b border-gray-200 dark:border-gray-700 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
      <%= link_to "General", new_account_path(tab: "general"), class: "#{@tab == 'general' ? 'border-indigo-500 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <% if @account.persisted? %>
        <%= link_to "Stores We Supply", new_account_path(tab: "stores_we_supply"), class: "#{@tab == 'stores_we_supply' ? 'border-indigo-500 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <% else %>
        <span class="border-transparent text-gray-400 cursor-not-allowed whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" title="Create account first to manage supply relationships">Stores We Supply</span>
      <% end %>
    </nav>
  </div>

  <div class="md:w-2/3 w-full">
    <% if @tab == "general" %>
      <%= render "form", account: @account %>
    <% elsif @tab == "stores_we_supply" && @account.persisted? %>
      <%= render "stores_we_supply", account: @account %>
    <% end %>

    <div class="mt-8">
      <%= link_to "Back to accounts", accounts_path, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 inline-block font-medium" %>
    </div>
  </div>
</div>
