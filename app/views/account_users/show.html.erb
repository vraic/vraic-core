<% content_for :title, "Showing account user" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing account user</h1>

  <%= render @account_user %>

  <div class="flex flex-wrap gap-2 mt-4">
    <%= link_to "Edit this account user", edit_account_user_path(@account_user), class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= link_to "Back to account users", account_users_path, class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= button_to "Destroy this account user", @account_user, method: :delete, form_class: "w-full sm:w-auto", class: danger_button_class("w-full"), data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
