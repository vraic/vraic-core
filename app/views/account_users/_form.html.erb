<%= form_with(model: account_user, class: "contents") do |form| %>
  <% if account_user.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(account_user.errors.count, "error") %> prohibited this account_user from being saved:</h2>

      <ul class="list-disc ml-6">
        <% account_user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if Current.user.admin? %>
    <div class="my-5">
      <%= form.label :account_id, class: label_class %>
      <%= form.select(:account_id, Account.unscoped.all.order(:name).map{|ac| [ac.name.to_s, ac.id]}, { selected: form.object.persisted? ? @account_user&.account_id : params[:account_id], include_blank: false }, class: input_class(account_user.errors[:account_id].any?)) %>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :user_id, class: label_class %>
    <%= form.select(:user_id, User.all.order(:name).map{|usr| [usr.name.to_s, usr.id]}, { selected: form.object.persisted? ? @account_user&.user_id : params[:user_id], include_blank: false }, class: input_class(account_user.errors[:user_id].any?)) %>
  </div>

  <div class="my-5">
    <%= form.label :user_role, class: label_class %>
    <%= form.select(:user_role, enum_options_for_select(@account_user, :user_role), { selected: form.object.persisted? ? @account_user&.user_role : params[:user_role], include_blank: false }, class: input_class(account_user.errors[:user_role].any?)) %>
  </div>

  <div class="inline">
    <%= form.submit class: primary_button_class("w-full sm:w-auto") %>
  </div>
<% end %>
