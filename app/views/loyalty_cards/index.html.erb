<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 dark:text-white sm:truncate sm:text-3xl sm:tracking-tight">
        Loyalty Program
      </h2>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= Current.account.name %></p>
    </div>
  </div>

  <% if @loyalty_program&.active? %>
    <div class="bg-indigo-50 dark:bg-indigo-900/20 shadow sm:rounded-2xl p-8 text-center">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-indigo-100 dark:bg-indigo-900/40 mb-6">
        <svg class="h-10 w-10 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
      </div>
      
      <h3 class="text-2xl font-bold text-indigo-900 dark:text-indigo-300 mb-4">Join our Loyalty Program!</h3>
      <div class="mx-auto max-w-2xl text-lg text-indigo-700 dark:text-indigo-400 mb-8">
        <p>Earn points on every purchase and redeem them for exclusive discounts. It's our way of saying thank you for shopping with us!</p>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="bg-white/50 dark:bg-indigo-900/20 p-4 rounded-xl border border-indigo-100 dark:border-indigo-800">
            <p class="font-bold text-indigo-900 dark:text-white">Earn</p>
            <p class="text-sm"><%= @loyalty_program.currency_to_points_ratio %> point(s) for every <%= Money.default_currency.symbol %>1 spent</p>
          </div>
          <div class="bg-white/50 dark:bg-indigo-900/20 p-4 rounded-xl border border-indigo-100 dark:border-indigo-800">
            <p class="font-bold text-indigo-900 dark:text-white">Redeem</p>
            <p class="text-sm">1 point = <%= humanized_money_with_symbol Money.new(@loyalty_program.points_to_currency_ratio * 100, Money.default_currency) %> discount</p>
          </div>
        </div>
      </div>
      
      <div class="flex justify-center">
        <%= button_to "Enroll Now", loyalty_cards_path, method: :post, class: "rounded-full bg-indigo-600 px-10 py-4 text-lg font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-all transform hover:scale-105" %>
      </div>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 shadow sm:rounded-2xl p-8 text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-700 mb-4">
        <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v.008Z" />
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 dark:text-white">Loyalty program unavailable</h3>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">The loyalty program is currently not active for this store.</p>
    </div>
  <% end %>
</div>
