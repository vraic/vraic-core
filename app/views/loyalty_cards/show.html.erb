<% content_for :title, "Loyalty Card - #{Current.account.name}" %>

<div class="max-w-2xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="mb-8">
    <%= link_to "← Back to Dashboard", dashboard_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>

  <div class="bg-indigo-600 rounded-3xl shadow-2xl overflow-hidden text-white mb-10 transform transition hover:scale-[1.02]">
    <div class="px-8 py-10 relative">
      <div class="flex justify-between items-start mb-12">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight"><%= Current.account.name %></h2>
          <p class="text-indigo-100 mt-1 uppercase tracking-widest text-xs font-semibold">Loyalty Member</p>
        </div>
        <% if Current.account.header_image.attached? %>
           <%= image_tag Current.account.header_image.variant(:thumb), class: "h-12 w-12 rounded-full ring-2 ring-white/50" %>
        <% end %>
      </div>

      <div class="flex justify-between items-end">
        <div>
          <div class="text-sm text-indigo-100 opacity-80 mb-1">Point Balance</div>
          <div class="text-5xl font-bold"><%= @loyalty_card.points_balance %></div>
        </div>
        <div class="text-right">
          <div class="text-sm text-indigo-100 opacity-80 mb-1">Card Holder</div>
          <div class="text-lg font-medium"><%= @loyalty_card.customer.name %></div>
        </div>
      </div>
      
      <!-- Decorative circles -->
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-indigo-400/20 rounded-full blur-2xl"></div>
    </div>
    
    <div class="bg-white px-8 py-10 flex flex-col items-center">
      <div class="bg-white p-4 rounded-xl shadow-inner border border-gray-100 mb-6">
        <% qrcode = RQRCode::QRCode.new(@loyalty_card.identifier) %>
        <%= qrcode.as_svg(
          color: "000",
          shape_rendering: "crispEdges",
          module_size: 5,
          standalone: true,
          use_path: true
        ).html_safe %>
      </div>
      <div class="text-gray-900 font-mono text-xl tracking-widest"><%= @loyalty_card.identifier %></div>
      <p class="text-gray-500 text-sm mt-2">Scan at checkout to earn or redeem points</p>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-4 mb-12">
    <%= link_to offline_loyalty_card_path(@loyalty_card), class: "flex-1 inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" do %>
      <svg class="-ml-1 mr-3 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 00-2 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 012-2H4a2 2 0 012 2v4a2 2 0 002 2zM15 11h.01" />
      </svg>
      Print Card (PDF)
    <% end %>
    
    <%= link_to wallet_loyalty_card_path(@loyalty_card), class: "flex-1 inline-flex justify-center items-center px-6 py-3 border border-gray-300 shadow-sm text-base font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50" do %>
      <svg class="-ml-1 mr-3 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
      </svg>
      Add to Wallet
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
      <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Earned</p>
      <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white"><%= @loyalty_card.total_points_earned %></p>
      <p class="mt-1 text-xs text-gray-400">Lifetime points accrued</p>
    </div>
    <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
      <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Redeemed</p>
      <p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white"><%= @loyalty_card.total_points_redeemed %></p>
      <p class="mt-1 text-xs text-gray-400">Points spent on rewards</p>
    </div>
    <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
      <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Lifetime Savings</p>
      <p class="mt-2 text-3xl font-bold text-green-600 dark:text-green-400"><%= humanized_money_with_symbol @loyalty_card.lifetime_savings %></p>
      <p class="mt-1 text-xs text-gray-400">Total value redeemed</p>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-2xl mb-12">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Membership Details</h3>
    </div>
    <div class="px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Member Since</dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @loyalty_card.created_at.strftime("%B %d, %Y") %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Store</dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= Current.account.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Earning Rate</dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @loyalty_card.loyalty_program.currency_to_points_ratio %> points per <%= Money.default_currency.symbol %>1 spent</dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Redemption Rate</dt>
          <dd class="mt-1 text-sm text-gray-900 dark:text-white">1 point = <%= humanized_money_with_symbol Money.new(@loyalty_card.loyalty_program.points_to_currency_ratio * 100, Money.default_currency) %> discount</dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-2xl">
    <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Transaction History</h3>
    </div>
    <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
      <% if @transactions.any? %>
        <% @transactions.each do |transaction| %>
          <li class="px-4 py-6 sm:px-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-bold text-gray-900 dark:text-white truncate">
                  <%= transaction.description %>
                </p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <%= transaction.created_at.strftime("%b %d, %Y %H:%M") %>
                </p>
              </div>
              <div class="ml-2 flex-shrink-0 flex">
                <p class="px-3 py-1 inline-flex text-sm leading-5 font-bold rounded-full <%= transaction.accrual? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                  <%= transaction.amount > 0 ? "+#{transaction.amount}" : transaction.amount %> points
                </p>
              </div>
            </div>
            
            <% if transaction.order %>
              <div class="mt-4 bg-gray-50 dark:bg-gray-900/50 rounded-lg p-4">
                <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">Order Breakdown (Order #<%= transaction.order.number %>)</p>
                <ul class="space-y-2">
                  <% transaction.order.order_items.each do |item| %>
                    <li class="flex justify-between text-sm">
                      <span class="text-gray-700 dark:text-gray-300"><%= item.quantity %>x <%= item.inventory_item.name %></span>
                      <span class="text-gray-500"><%= humanized_money_with_symbol item.total_price %></span>
                    </li>
                  <% end %>
                </ul>
                <div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-700 flex justify-between font-bold text-sm">
                  <span class="text-gray-900 dark:text-white">Order Total</span>
                  <span class="text-gray-900 dark:text-white"><%= humanized_money_with_symbol transaction.order.total_amount %></span>
                </div>
                <% if transaction.redemption? %>
                   <div class="mt-1 flex justify-between text-sm text-indigo-600 dark:text-indigo-400 font-medium italic">
                    <span>Loyalty Discount Applied</span>
                    <span>-<%= humanized_money_with_symbol transaction.order.loyalty_discount %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </li>
        <% end %>
      <% else %>
        <li class="px-4 py-10 text-center text-gray-500 dark:text-gray-400">
          No transactions yet.
        </li>
      <% end %>
    </ul>
  </div>
</div>
