<div id="<%= dom_id inventory_item %>" class="w-full py-5 border-b border-gray-200 dark:border-gray-700 last:border-0">
  <div class="flex justify-between items-start">
    <div>
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
        <%= link_to inventory_item.display_name, inventory_item, class: "hover:text-indigo-600" %>
      </h3>
      <% if inventory_item.inventory_group %>
        <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10 dark:bg-gray-400/10 dark:text-gray-400 dark:ring-gray-400/20">
          <%= inventory_item.inventory_group.name %>
        </span>
      <% end %>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
        <%= inventory_item.description %>
      </p>
    </div>
    <div class="text-right">
      <div class="text-lg font-bold text-gray-900 dark:text-white">
        <%= humanized_money_with_symbol inventory_item.price %>
      </div>
      <div class="text-sm text-gray-500 dark:text-gray-400">
        Stock: <%= pluralize(inventory_item.total_quantity, inventory_item.stock_unit) %>
        <% if inventory_item.locations.any? %>
          across <%= pluralize(inventory_item.locations.count, 'location') %>
        <% else %>
          (No location set)
        <% end %>
      </div>
    </div>
  </div>
</div>
