<% content_for :title, "Showing inventory item" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl text-gray-900 dark:text-white"><%= @inventory_item.display_name %></h1>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_inventory_item_path(@inventory_item), class: secondary_button_class %>
      <%= link_to "Back", inventory_items_path, class: secondary_button_class %>
      <%= button_to "Destroy", @inventory_item, method: :delete, class: danger_button_class, data: { turbo_confirm: "Are you sure?" } %>
      <% if policy(@inventory_item).really_destroy? %>
        <%= button_to "Really Delete", really_destroy_inventory_item_path(@inventory_item), method: :delete, class: danger_button_class("bg-red-800 hover:bg-red-700"), data: { turbo_confirm: "Are you sure? This is permanent." } %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-bold mb-4">Details</h2>
        <div class="space-y-4">
          <p class="text-gray-600 dark:text-gray-400"><%= @inventory_item.description %></p>
          <div class="flex gap-8">
            <div>
              <span class="block text-sm font-medium text-gray-500 uppercase">Price</span>
              <span class="text-2xl font-bold"><%= humanized_money_with_symbol @inventory_item.price %></span>
            </div>
            <div>
              <span class="block text-sm font-medium text-gray-500 uppercase">Pricing Unit</span>
              <span class="text-lg font-semibold">
                <% if @inventory_item.per_weight? %>
                  Per <%= @inventory_item.weight_value %> <%= @inventory_item.weight_unit %>
                <% else %>
                  Per unit
                <% end %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <% if @inventory_item.parent.nil? %>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold">Variants</h2>
            <%= link_to "Add Variant", new_inventory_item_path(parent_id: @inventory_item.id), class: secondary_button_class, id: "add_variant", data: { turbo: false } %>
          </div>
          <div class="mt-4 <%= table_container_class %>">
            <table class="<%= table_class %>">
              <thead class="<%= thead_class %>">
                <tr>
                  <th class="<%= th_class %>">Variant</th>
                  <th class="<%= th_class %> text-right">Price</th>
                  <th class="<%= th_class %> text-right">Stock</th>
                </tr>
              </thead>
              <tbody class="<%= tbody_class %>">
                <% if @variants.any? %>
                  <% @variants.each do |variant| %>
                    <tr>
                      <td class="<%= td_class %>">
                        <%= link_to variant.display_name, variant, class: "text-indigo-600 hover:text-indigo-900 font-semibold" %>
                      </td>
                      <td class="<%= td_class %> text-right">
                        <%= humanized_money_with_symbol variant.price %>
                      </td>
                      <td class="<%= td_class %> text-right">
                        <%= pluralize(variant.total_quantity, variant.stock_unit) %>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="3" class="<%= td_class %> text-center py-4 text-gray-500">No variants for this item.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>
    </div>

    <div class="space-y-8">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-bold mb-4">Stock Levels</h2>
        <div class="space-y-4">
          <% @inventory_levels.each do |level| %>
            <div class="flex justify-between items-center">
              <span class="font-medium"><%= level.location.name %></span>
              <span class="text-lg"><%= pluralize(level.quantity, @inventory_item.stock_unit) %></span>
            </div>
          <% end %>
          <% if @inventory_levels.empty? %>
            <p class="text-gray-500">No stock levels recorded.</p>
          <% end %>
          <div class="pt-4 border-t border-gray-200 dark:border-gray-700 mt-4 flex justify-between items-center font-bold">
            <span>Total Stock</span>
            <span><%= pluralize(@inventory_item.total_quantity, @inventory_item.stock_unit) %></span>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
        <h2 class="text-xl font-bold mb-4">Adjust Stock</h2>
        <%= form_with(url: inventory_item_inventory_levels_path(@inventory_item), class: "space-y-4") do |f| %>
          <div>
            <%= f.label :location_id, "Location", class: label_class %>
            <%= f.collection_select :location_id, @locations, :id, :name, {}, class: input_class %>
          </div>
          <div>
            <%= f.label :quantity, "New Total Quantity", class: label_class %>
            <%= f.number_field :quantity, class: input_class %>
          </div>
          <%= f.submit "Update Stock", class: primary_button_class("w-full") %>
        <% end %>
      </div>

      <% if @inventory_levels.count > 0 && @locations.count > 1 %>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
          <h2 class="text-xl font-bold mb-4">Transfer Stock</h2>
          <%= form_with(url: transfer_inventory_item_inventory_levels_path(@inventory_item), class: "space-y-4") do |f| %>
            <div>
              <%= f.label :from_location_id, "From Location", class: label_class %>
              <%= f.collection_select :from_location_id, @inventory_item.locations, :id, :name, {}, class: input_class %>
            </div>
            <div>
              <%= f.label :to_location_id, "To Location", class: label_class %>
              <%= f.collection_select :to_location_id, @locations, :id, :name, {}, class: input_class %>
            </div>
            <div>
              <%= f.label :transfer_quantity, "Quantity to Move", class: label_class %>
              <%= f.number_field :transfer_quantity, class: input_class %>
            </div>
            <%= f.submit "Transfer", class: secondary_button_class("w-full") %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
