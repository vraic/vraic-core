<h1>Order Received - #<%= @order.prefix_id %></h1>

<p>Hi <%= @customer.name %>,</p>

<p>Thank you for your order. We have received it and are currently processing it.</p>

<h3>Order Details</h3>
<ul>
  <% @order.order_items.each do |item| %>
    <li><%= item.inventory_item.display_name %> x <%= item.quantity %></li>
  <% end %>
</ul>

<p>Total: <%= @order.total_amount.format %></p>

<p>We will notify you once it's ready for collection.</p>