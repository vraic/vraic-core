<% content_for :title, "Account Settings" %>

<div class="-m-4 sm:-m-6 lg:-m-8">
  <main>
    <h1 class="sr-only">Account Settings</h1>

    <header class="border-b border-gray-200 dark:border-white/5">
      <!-- Secondary navigation -->
      <nav class="flex overflow-x-auto py-4">
        <ul role="list" class="flex min-w-full flex-none gap-x-6 px-4 text-sm/6 font-semibold text-gray-500 sm:px-6 lg:px-8 dark:text-gray-400">
          <li>
            <%= link_to "Account", settings_path, class: "text-indigo-600 dark:text-indigo-400" %>
          </li>
          <li>
            <a href="#" class="">Notifications</a>
          </li>
        </ul>
      </nav>
    </header>

    <!-- Settings forms -->
    <div class="divide-y divide-gray-200 dark:divide-white/10">
      <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 px-4 py-16 sm:px-6 md:grid-cols-3 lg:px-8">
        <div>
          <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Personal Information</h2>
          <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">Use a permanent address where you can receive mail.</p>
        </div>

        <%= form_with model: @user, url: settings_path, method: :patch, class: "md:col-span-2" do |f| %>
          <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:max-w-xl sm:grid-cols-6">

            <div class="col-span-full">
              <%= f.label :name, "Name", for: "name", class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= f.text_field :name, id: "name", autocomplete: "name", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>

            <div class="col-span-full">
              <%= f.label :email_address, "Email address", for: "email", class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= f.email_field :email_address, id: "email", autocomplete: "email", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>
          </div>

          <div class="mt-8 flex">
            <%= f.submit "Save", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
          </div>
        <% end %>
      </div>

      <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 px-4 py-16 sm:px-6 md:grid-cols-3 lg:px-8">
        <div>
          <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Two-Factor Authentication</h2>
          <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">Add an additional layer of security to your account.</p>
        </div>

        <div class="md:col-span-2">
          <% if @user.otp_enabled? %>
            <div class="flex items-center gap-x-4">
              <div class="flex-none rounded-full bg-green-100 p-1 text-green-600 dark:bg-green-900/30 dark:text-green-400">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-sm font-medium text-gray-900 dark:text-white">2FA is currently enabled via Authenticator App.</p>
            </div>
            <div class="mt-4">
              <%= button_to "Disable 2FA", two_factor_auth_path, method: :delete, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:ring-white/5 dark:hover:bg-white/20" %>
            </div>
          <% else %>
            <div class="flex items-center gap-x-4 text-gray-500 dark:text-gray-400">
              <p class="text-sm">2FA is currently disabled. Authenticator App is recommended, but Email 2FA will be used as a fallback if not configured.</p>
            </div>
            <div class="mt-4">
              <%= link_to "Setup Authenticator App", two_factor_auth_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 px-4 py-16 sm:px-6 md:grid-cols-3 lg:px-8">
        <div>
          <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Change password</h2>
          <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">Update your password associated with your account.</p>
        </div>

        <%= form_with model: @user, url: update_password_settings_path, method: :patch, class: "md:col-span-2" do |f| %>
          <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:max-w-xl sm:grid-cols-6">
            <div class="col-span-full">
              <label for="current-password" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Current password</label>
              <div class="mt-2">
                <%= password_field_tag :current_password, nil, id: "current-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>

            <div class="col-span-full">
              <%= f.label :password, "New password", for: "new-password", class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= f.password_field :password, id: "new-password", autocomplete: "new-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>

            <div class="col-span-full">
              <%= f.label :password_confirmation, "Confirm password", for: "confirm-password", class: "block text-sm/6 font-medium text-gray-900 dark:text-white" %>
              <div class="mt-2">
                <%= f.password_field :password_confirmation, id: "confirm-password", autocomplete: "new-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>
          </div>

          <div class="mt-8 flex">
            <%= f.submit "Save", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
          </div>
        <% end %>
      </div>

      <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 px-4 py-16 sm:px-6 md:grid-cols-3 lg:px-8">
        <div>
          <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Log out other sessions</h2>
          <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">Please enter your password to confirm you would like to log out of your other sessions across all of your devices.</p>
        </div>

        <%= form_with url: logout_sessions_settings_path, method: :post, class: "md:col-span-2" do |f| %>
          <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:max-w-xl sm:grid-cols-6">
            <div class="col-span-full">
              <label for="logout-password" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Your password</label>
              <div class="mt-2">
                <%= password_field_tag :password, nil, id: "logout-password", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
              </div>
            </div>
          </div>

          <div class="mt-8 flex">
            <%= f.submit "Log out other sessions", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
          </div>
        <% end %>
      </div>

      <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 px-4 py-16 sm:px-6 md:grid-cols-3 lg:px-8">
        <div>
          <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Delete account</h2>
          <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">No longer want to use our service? You can delete your account here. This action is not reversible. All information related to this account will be deleted permanently.</p>
        </div>

        <%= form_with model: @user, url: settings_path, method: :delete, class: "flex items-start md:col-span-2", data: { turbo_confirm: "Are you sure you want to delete your account? This cannot be undone." } do |f| %>
          <%= f.submit "Yes, delete my account", class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-red-500 dark:bg-red-500 dark:shadow-none dark:hover:bg-red-400" %>
        <% end %>
      </div>
    </div>
  </main>
</div>
