<div class="mx-auto w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl"><%= @newsletter.subject %></h1>
    <div class="flex gap-2">
      <% unless @newsletter.sent? %>
        <%= link_to "Edit", edit_newsletter_path(@newsletter), class: secondary_button_class %>
        <%= button_to "Deliver Now", deliver_newsletter_path(@newsletter), method: :post, data: { confirm: "Are you sure you want to send this newsletter?" }, class: primary_button_class %>
      <% end %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <% if @newsletter.sent? %>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-indigo-50 dark:bg-indigo-900/30 p-4 rounded-lg">
          <div class="text-indigo-600 dark:text-indigo-400 text-sm font-semibold uppercase tracking-wider">Sent</div>
          <div class="text-2xl font-bold dark:text-gray-100"><%= @newsletter.total_sent %></div>
        </div>
        <div class="bg-green-50 dark:bg-green-900/30 p-4 rounded-lg">
          <div class="text-green-600 dark:text-green-400 text-sm font-semibold uppercase tracking-wider">Opened</div>
          <div class="text-2xl font-bold dark:text-gray-100"><%= @newsletter.total_opened %></div>
          <div class="text-xs text-green-500 font-medium"><%= @newsletter.open_rate %>% open rate</div>
        </div>
        <div class="bg-blue-50 dark:bg-blue-900/30 p-4 rounded-lg">
          <div class="text-blue-600 dark:text-blue-400 text-sm font-semibold uppercase tracking-wider">Clicked</div>
          <div class="text-2xl font-bold dark:text-gray-100"><%= @newsletter.total_clicked %></div>
          <div class="text-xs text-blue-500 font-medium"><%= @newsletter.click_rate %>% click rate</div>
        </div>
        <div class="bg-purple-50 dark:bg-purple-900/30 p-4 rounded-lg">
          <div class="text-purple-600 dark:text-purple-400 text-sm font-semibold uppercase tracking-wider">Recipients</div>
          <div class="text-2xl font-bold dark:text-gray-100"><%= @newsletter.target.titleize %></div>
        </div>
      </div>
    <% end %>

    <div class="flex flex-col gap-4 mb-6">
      <div>
        <span class="text-sm font-semibold text-gray-500 dark:text-gray-400">Target:</span>
        <span class="text-sm font-medium dark:text-gray-200"><%= @newsletter.target.titleize %></span>
      </div>
      <div>
        <span class="text-sm font-semibold text-gray-500 dark:text-gray-400">Sent At:</span>
        <span class="text-sm font-medium dark:text-gray-200"><%= @newsletter.sent_at&.strftime("%b %d, %Y %H:%M") || "Not sent yet" %></span>
      </div>
    </div>

    <hr class="my-6 border-gray-200 dark:border-gray-700">

    <div class="prose max-w-none dark:prose-invert">
      <%= @newsletter.content %>
    </div>
  </div>

  <% if @newsletter.sent? %>
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
      <h2 class="text-xl font-bold mb-4 dark:text-gray-100">Delivery Details</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead>
            <tr>
              <th class="px-6 py-3 bg-gray-50 dark:bg-gray-700 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Recipient</th>
              <th class="px-6 py-3 bg-gray-50 dark:bg-gray-700 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 bg-gray-50 dark:bg-gray-700 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Opened At</th>
              <th class="px-6 py-3 bg-gray-50 dark:bg-gray-700 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Clicked At</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @messages.each do |message| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-200">
                  <%= message.user&.name || message.to %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <% if message.clicked_at %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">Clicked</span>
                  <% elsif message.opened_at %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Opened</span>
                  <% else %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Sent</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= message.opened_at&.strftime("%b %d, %H:%M") || "-" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= message.clicked_at&.strftime("%b %d, %H:%M") || "-" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if defined?(Pagy) && @pagy.pages > 1 %>
        <div class="mt-4">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= link_to "Back to newsletters", newsletters_path, class: "rounded-lg py-3 px-5 bg-gray-100 dark:bg-gray-700 dark:text-gray-200 inline-block font-medium" %>
</div>
