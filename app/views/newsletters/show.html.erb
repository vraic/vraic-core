<div class="mx-auto w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl"><%= @newsletter.subject %></h1>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_newsletter_path(@newsletter), class: secondary_button_class %>
      <%= button_to "Deliver Now", deliver_newsletter_path(@newsletter), method: :post, data: { confirm: "Are you sure you want to send this newsletter?" }, class: primary_button_class %>
    </div>
  </div>

  <div class="bg-white p-6 rounded-lg shadow border border-gray-200 mb-6 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex flex-col gap-4 mb-6">
      <div>
        <span class="text-sm font-semibold text-gray-500 dark:text-gray-400">Target:</span>
        <span class="text-sm font-medium dark:text-gray-200"><%= @newsletter.target.titleize %></span>
      </div>
      <div>
        <span class="text-sm font-semibold text-gray-500 dark:text-gray-400">Sent At:</span>
        <span class="text-sm font-medium dark:text-gray-200"><%= @newsletter.sent_at&.strftime("%b %d, %Y %H:%M") || "Not sent yet" %></span>
      </div>
    </div>

    <hr class="my-6 border-gray-200 dark:border-gray-700">

    <div class="prose max-w-none dark:prose-invert">
      <%= @newsletter.content %>
    </div>
  </div>

  <%= link_to "Back to newsletters", newsletters_path, class: "rounded-lg py-3 px-5 bg-gray-100 dark:bg-gray-700 dark:text-gray-200 inline-block font-medium" %>
</div>
