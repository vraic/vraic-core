<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "vraic.je" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Vraic OS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "lexxy-content", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 h-full">


    <el-dialog>
      <% unless content_for?(:no_sidebar) %>
        <dialog id="sidebar" class="backdrop:bg-transparent lg:hidden">
        <el-dialog-backdrop class="fixed inset-0 bg-gray-900/80 transition-opacity duration-300 ease-linear data-closed:opacity-0"></el-dialog-backdrop>

        <div tabindex="0" class="fixed inset-0 flex focus:outline-none">
          <el-dialog-panel class="group/dialog-panel relative mr-16 flex w-full max-w-xs flex-1 transform transition duration-300 ease-in-out data-closed:-translate-x-full">
            <div class="absolute top-0 left-full flex w-16 justify-center pt-5 duration-300 ease-in-out group-data-closed/dialog-panel:opacity-0">
              <button type="button" command="close" commandfor="sidebar" class="-m-2.5 p-2.5">
                <span class="sr-only">Close sidebar</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 text-white">
                  <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>

            <!-- Sidebar component, swap this element with another sidebar if you like -->
            <div class="relative flex grow flex-col gap-y-5 overflow-y-auto bg-white px-6 pb-2 dark:bg-gray-900 dark:ring dark:ring-white/10 dark:before:pointer-events-none dark:before:absolute dark:before:inset-0 dark:before:bg-black/10">
              <div class="relative flex h-16 shrink-0 items-center">
                <%= image_tag "icon.svg", alt: "Vraic", class: "h-8 w-auto dark:hidden" %>
                <%= image_tag "icon.svg", alt: "Vraic", class: "h-8 w-auto not-dark:hidden" %>
              </div>
              <nav id="mobile-sidebar-main-nav" class="relative flex flex-1 flex-col">
                <ul role="list" class="flex flex-1 flex-col gap-y-7">
                  <li>
                    <ul role="list" class="-mx-2 space-y-1">
                      <li>
                        <%= link_to root_path, class: nav_link_classes(:dashboard) do %>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:dashboard) %>">
                            <path d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          Dashboard
                        <% end %>
                      </li>
                      <% if staff? %>
                        <li>
                          <%= link_to tasks_path, class: nav_link_classes(:tasks) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:tasks) %>">
                              <path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Tasks
                          <% end %>
                        </li>
                        <li>
                          <%= link_to customers_path, class: nav_link_classes(:customers) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:customers) %>">
                              <path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Customers
                          <% end %>
                        </li>
                        <li>
                          <%= link_to suppliers_path, class: nav_link_classes(:suppliers) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:suppliers) %>">
                              <path d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Suppliers
                          <% end %>
                        </li>
                        <li>
                          <%= link_to inventory_items_path, class: nav_link_classes(:inventory) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:inventory) %>">
                              <path d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Inventory
                          <% end %>
                        </li>
                      <% end %>
                      <li>
                        <%= link_to orders_path, class: nav_link_classes(:orders) do %>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:orders) %>">
                            <path d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          Orders
                        <% end %>
                      </li>
                      <% if staff? %>
                        <li>
                          <%= link_to reports_path, class: nav_link_classes(:reports) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:reports) %>">
                              <path d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" stroke-linecap="round" stroke-linejoin="round" />
                              <path d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Reports
                          <% end %>
                        </li>
                        <li>
                          <%= link_to newsletters_path, class: nav_link_classes(:newsletters) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:newsletters) %>">
                              <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Newsletters
                          <% end %>
                        </li>
                      <% end %>
                    <% if customer? && loyalty_program&.active? %>
                      <li>
                        <%= link_to customer_newsletters_path, class: nav_link_classes(:customer_newsletters) do %>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:customer_newsletters) %>">
                            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          Newsletters
                        <% end %>
                      </li>
                      <li>
                        <%= link_to loyalty_cards_path, class: nav_link_classes(:loyalty) do %>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:loyalty) %>">
                            <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          Loyalty
                        <% end %>
                      </li>
                    <% elsif customer? %>
                      <li>
                        <%= link_to customer_newsletters_path, class: nav_link_classes(:customer_newsletters) do %>
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:customer_newsletters) %>">
                            <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          Newsletters
                        <% end %>
                      </li>
                    <% end %>
                      <% if manager? %>
                        <li>
                          <%= link_to edit_account_path(Current.account), class: nav_link_classes(:accounts) do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:accounts) %>">
                              <path d="M13.5 21V12.75H10.5V21M4.5 21H19.5M3 12.75H21M5.25 12.75V5.25C5.25 4.85218 5.40804 4.47064 5.68934 4.18934C5.97064 3.90804 6.35218 3.75 6.75 3.75H17.25C17.6478 3.75 18.0294 3.90804 18.3107 4.18934C18.592 4.47064 18.75 4.85218 18.75 5.25V12.75" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Store Settings
                          <% end %>
                        </li>
                      <% end %>
                    </ul>
                  </li>
                  <% if staff? %>
                    <li>
                      <div class="text-xs/6 font-semibold text-gray-400">Quick links</div>
                        <ul role="list" class="-mx-2 mt-2 space-y-1">
                          <li>
                            <%= link_to orders_path(filter: "today"), class: "group flex gap-x-3 rounded-md p-2 text-sm/6 font-semibold text-gray-700 hover:bg-gray-50 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white" do %>
                              <span class="flex size-6 shrink-0 items-center justify-center rounded-lg border border-gray-200 bg-white text-[0.625rem] font-medium text-gray-400 group-hover:border-indigo-600 group-hover:text-indigo-600 dark:border-white/10 dark:bg-white/5 dark:group-hover:border-white/20 dark:group-hover:text-white">1</span>
                              <span class="truncate">Today's Orders</span>
                            <% end %>
                          </li>
                          <li>
                            <%= link_to customers_path(filter: "recent"), class: "group flex gap-x-3 rounded-md p-2 text-sm/6 font-semibold text-gray-700 hover:bg-gray-50 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white" do %>
                              <span class="flex size-6 shrink-0 items-center justify-center rounded-lg border border-gray-200 bg-white text-[0.625rem] font-medium text-gray-400 group-hover:border-indigo-600 group-hover:text-indigo-600 dark:border-white/10 dark:bg-white/5 dark:group-hover:border-white/20 dark:group-hover:text-white">2</span>
                              <span class="truncate">Recent Customers</span>
                            <% end %>
                          </li>
                        </ul>
                      </li>
                    <% end %>
                </ul>
              </nav>
              <% if authenticated? %>
                <ul role="list" class="-mx-2 space-y-1 mt-auto">
                  <% if Current.user&.admin? %>
                    <li>
                      <%= link_to accounts_path, class: nav_link_classes(:accounts) do %>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="<%= nav_icon_classes(:accounts) %>">
                          <path d="M10.34 15.84c-.68-.34-1.16-.94-1.34-1.63L8.75 13l-1.47-.49c-.69-.23-1.22-.73-1.46-1.4l-.12-.34c-.2-.55-.16-1.16.12-1.68l.38-.52c.38-.52.95-.84 1.58-.9l1.47-.13.34-1.36c.17-.69.64-1.25 1.28-1.52l.34-.12c.55-.2 1.16-.16 1.68.12l.52.38c.52.38.84.95.9 1.58l.13 1.47 1.36.34c.69.17 1.25.64 1.52 1.28l.12.34c.2.55.16 1.16-.12 1.68l-.38.52c-.38.52-.95.84-1.58.9l-1.47.13-.34 1.36c-.17.69-.64 1.25-1.28 1.52l-.34.12c-.55.2-1.16.16-1.68-.12l-.52-.38c-.52-.38-.84-.95-.9-1.58l-.13-1.47-1.36-.34Z" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Administration
                      <% end %>
                    </li>
                  <% end %>
                  <% if switchable_accounts.size > 1 %>
                    <li>
                      <button type="button" command="show-modal" commandfor="account-switcher" class="group flex w-full gap-x-3 rounded-md p-2 text-sm/6 font-semibold text-gray-700 hover:text-indigo-600 hover:bg-gray-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5">
                        <svg class="size-6 shrink-0 text-gray-400 group-hover:text-indigo-600 dark:group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                        </svg>
                        Switch Account
                      </button>
                    </li>
                  <% end %>
                </ul>

                <div class="-mx-6 mt-auto border-t border-gray-200 dark:border-white/10">
                  <div class="relative" data-controller="dropdown" data-action="click@window->dropdown#hide">
                    <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-x-4 px-6 py-3 text-sm font-semibold leading-6 text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5 w-full text-left" id="user-menu-button-mobile" aria-expanded="false" aria-haspopup="true">
                      <span class="sr-only">Your profile</span>
                      <span class="flex flex-col truncate">
                        <span aria-hidden="true" class="truncate"><%= Current.user&.name %></span>
                        <span aria-hidden="true" class="text-xs text-gray-500 truncate font-normal"><%= current_user_role %></span>
                      </span>
                      <svg class="size-5 text-gray-400 ml-auto" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 17a.75.75 0 0 1-.75-.75V5.612l-3.96 4.158a.75.75 0 1 1-1.08-1.04l5.25-5.5a.75.75 0 0 1 1.08 0l5.25 5.5a.75.75 0 1 1-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0 1 10 17Z" clip-rule="evenodd" />
                      </svg>
                    </button>

                    <div data-dropdown-target="menu" class="hidden absolute bottom-full left-0 z-10 w-64 mb-2 ml-4 origin-bottom-left rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5 focus:outline-none dark:bg-gray-800 dark:ring-white/10" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button-mobile" tabindex="-1">
                      <%= link_to "Settings", settings_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-white/5", role: "menuitem", tabindex: "-1" %>
                      <%= link_to "Support", support_requests_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-white/5", role: "menuitem", tabindex: "-1" %>
                      <div class="border-t border-gray-100 dark:border-white/5 my-1"></div>
                      <%= button_to "Logout", session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-white/5 cursor-pointer", role: "menuitem", tabindex: "-1" %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </el-dialog-panel>
        </div>
      </dialog>

      <dialog id="account-switcher" class="backdrop:bg-transparent bg-transparent border-0 p-0 overflow-visible">
        <el-dialog-backdrop class="fixed inset-0 bg-gray-900/80 transition-opacity duration-300 ease-linear data-closed:opacity-0" command="close" commandfor="account-switcher"></el-dialog-backdrop>
        <div class="fixed inset-0 z-[70] flex items-center justify-center p-4 pointer-events-none">
          <el-dialog-panel class="relative w-full max-w-md transform overflow-hidden rounded-lg bg-white p-6 text-left shadow-xl transition-all dark:bg-gray-800 dark:ring-1 dark:ring-white/10 pointer-events-auto">
            <div class="absolute top-0 right-0 pt-4 pr-4">
              <button type="button" command="close" commandfor="account-switcher" class="rounded-md bg-white text-gray-400 hover:text-gray-500 focus:outline-none dark:bg-gray-800 dark:text-gray-500 dark:hover:text-gray-400">
                <span class="sr-only">Close</span>
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <div>
              <h3 class="text-base font-semibold leading-6 text-gray-900 dark:text-white" id="modal-title">Switch Account</h3>
              <div class="mt-4">
                <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
                  <% switchable_accounts.each do |entry| %>
                    <li class="py-4">
                      <div class="flex items-center justify-between">
                        <div class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-white"><%= entry[:name] %></span>
                          <span class="text-xs text-gray-500 dark:text-gray-400"><%= entry[:role] %></span>
                        </div>
                        <% if Current.account&.id == entry[:id] %>
                          <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/20 dark:text-green-400 dark:ring-green-500/20">Active</span>
                        <% else %>
                          <%= button_to "Switch", managed_account_path(account_id: entry[:id]), method: :patch, class: "rounded bg-white px-2 py-1 text-xs font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-gray-700 dark:text-white dark:ring-gray-600 dark:hover:bg-gray-600" %>
                        <% end %>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </el-dialog-panel>
        </div>
      </dialog>
      <% end %>
    </el-dialog>

    <!-- Static sidebar for desktop -->
    <% unless content_for?(:no_sidebar) %>
      <div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-72 lg:flex-col dark:bg-gray-900">
      <!-- Sidebar component, swap this element with another sidebar if you like -->
      <div class="flex grow flex-col gap-y-5 overflow-y-auto border-r border-gray-200 bg-white px-6 dark:border-white/10 dark:bg-black/10">
        <div class="flex h-16 shrink-0 items-center">
          <%= image_tag "icon.svg", alt: "Vraic", class: "h-8 w-auto dark:hidden" %>
