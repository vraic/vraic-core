<% if Current.user&.admin? %>
  <div class="mb-6 px-2">
    <%= form_with url: managed_account_path, method: :patch, class: "flex flex-col gap-2", data: { turbo_frame: "_top" } do |f| %>
      <%= f.label :account_id, "Managing Account", class: "text-xs font-semibold text-gray-400 uppercase tracking-wider" %>
      <div class="flex gap-2">
        <%= f.collection_select :account_id, Account.all, :id, :name, { selected: Current.account&.id, include_blank: "All Accounts (Global)" }, class: input_class %>
        <%= f.submit "Go", class: secondary_button_class("px-2.5") %>
      </div>
    <% end %>
  </div>
<% end %>
