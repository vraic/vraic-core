<% if authenticated? %>
  <% 
    accounts = Current.user.admin? ? Account.all : Current.user.accounts
    show_switcher = Current.user.admin? || accounts.count > 1
  %>
  
  <% if show_switcher %>
    <div class="mb-6 px-2">
      <%= form_with url: managed_account_path, method: :patch, class: "flex flex-col gap-2", data: { turbo_frame: "_top" } do |f| %>
        <%= f.label :account_id, Current.user.admin? ? "Managing Account" : "Select Store", class: "text-xs font-semibold text-gray-400 uppercase tracking-wider" %>
        <div class="flex gap-2">
          <% 
            options = options_from_collection_for_select(accounts, :id, :name, Current.account&.id)
            include_blank = Current.user.admin? ? "All Accounts (Global)" : false
          %>
          <%= f.select :account_id, options, { include_blank: include_blank }, class: input_class %>
          <%= f.submit "Go", class: secondary_button_class("px-2.5") %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
