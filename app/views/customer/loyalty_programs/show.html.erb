<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-8">
    <%= link_to customer_loyalty_programs_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 flex items-center mb-4" do %>
      <svg class="mr-1 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      Back to All Programmes
    <% end %>
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white"><%= @loyalty_program.account.name %> Loyalty</h1>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <!-- Stats Cards -->
    <div class="lg:col-span-2 space-y-6">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border border-gray-200 dark:border-gray-700">
          <dt class="text-sm font-medium text-gray-500 truncate">Current Balance</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-indigo-600"><%= @loyalty_card.points_balance %></dd>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border border-gray-200 dark:border-gray-700">
          <dt class="text-sm font-medium text-gray-500 truncate">Lifetime Earned</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white"><%= @loyalty_card.total_points_earned %></dd>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border border-gray-200 dark:border-gray-700">
          <dt class="text-sm font-medium text-gray-500 truncate">Lifetime Savings</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-green-600"><%= number_to_currency @loyalty_card.lifetime_savings %></dd>
        </div>
      </div>

      <!-- Transaction History -->
      <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">Recent Activity</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900/50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @transactions.each do |tx| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= tx.created_at.to_fs(:short) %></td>
                  <td class="px-6 py-4 text-sm text-gray-900 dark:text-white"><%= tx.description %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium <%= tx.accrual? ? 'text-green-600' : 'text-red-600' %>">
                    <%= tx.accrual? ? '+' : '-' %><%= tx.amount.abs %>
                  </td>
                </tr>
              <% end %>
              <% if @transactions.empty? %>
                <tr>
                  <td colspan="3" class="px-6 py-10 text-center text-sm text-gray-500 italic">No transactions yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Info Sidebar -->
    <div class="space-y-6">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow border border-gray-200 dark:border-gray-700">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Programme Info</h3>
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Earnings</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">Earn <%= @loyalty_program.currency_to_points(1) %> points for every <%= number_to_currency(1) %> spent.</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Redemption</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-white">Every 100 points = <%= number_to_currency @loyalty_program.points_to_currency(100) %> discount.</dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Card Identifier</dt>
            <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white"><%= @loyalty_card.identifier %></dd>
          </div>
        </dl>
      </div>

      <div class="flex flex-col gap-3">
        <%= link_to "Download PDF Card", offline_loyalty_card_path(@loyalty_card), class: secondary_button_class("w-full justify-center") %>
        <%= link_to "Add to Apple Wallet", wallet_loyalty_card_path(@loyalty_card), class: secondary_button_class("w-full justify-center") %>
      </div>
    </div>
  </div>
</div>
