<% content_for :title, "Newsletters" %>

<div class="sm:flex sm:items-center mb-8">
  <div class="sm:flex-auto">
    <h1 class="text-2xl font-bold leading-6 text-gray-900 dark:text-white">Your Newsletters</h1>
    <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Manage your newsletter subscriptions across all stores.</p>
  </div>
</div>

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
  <% @customers.each do |customer| %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden" data-testid="subscription-card-<%= customer.account_id %>">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white truncate"><%= customer.account.name %></h3>
        <div class="mt-4 flex items-center justify-between">
          <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium <%= customer.subscribed_to_newsletter? ? 'bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/20 dark:text-green-400 dark:ring-green-500/20' : 'bg-gray-50 text-gray-600 ring-1 ring-inset ring-gray-500/10 dark:bg-gray-700 dark:text-gray-400 dark:ring-gray-600' %>">
            <%= customer.subscribed_to_newsletter? ? 'Subscribed' : 'Not Subscribed' %>
          </span>
          <% if customer.subscribed_to_newsletter? %>
            <%= button_to "Unsubscribe", unsubscribe_customer_newsletter_path(customer), method: :post, class: "text-sm font-medium text-red-600 hover:text-red-500" %>
          <% else %>
             <%= button_to "Subscribe", subscribe_customer_newsletters_path(account_id: customer.account_id), method: :post, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-16">
  <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Recent Archives</h2>
  <% if @newsletters.any? %>
    <div class="flow-root">
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
          <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6 dark:text-white">Store</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Subject</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Date</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                    <span class="sr-only">View</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-900">
                <% @newsletters.each do |newsletter| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6 dark:text-white">
                      <%= newsletter.account.name %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">
                      <%= newsletter.subject %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">
                      <%= newsletter.sent_at.to_fs(:short) %>
                    </td>
                    <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                      <%= link_to "View", customer_newsletter_path(newsletter), class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow-sm border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
      <p class="text-sm text-gray-500 dark:text-gray-400">No newsletters found for your active subscriptions.</p>
    </div>
  <% end %>
</div>
