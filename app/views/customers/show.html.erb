<% content_for :title, "Showing customer" %>

<div class="md:w-2/3 w-full">
  
  <h1 class="font-bold text-4xl">Showing customer</h1>

  <%= render @customer %>

  <div class="flex flex-wrap gap-2 mt-4">
    <%= link_to "Edit this customer", edit_customer_path(@customer), class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= link_to "Back to customers", customers_path, class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= button_to "Destroy this customer", @customer, method: :delete, form_class: "w-full sm:w-auto", class: danger_button_class("w-full"), data: { turbo_confirm: "Are you sure?" } %>
    <% if policy(@customer).really_destroy? %>
      <%= button_to "Really Delete", really_destroy_customer_path(@customer), method: :delete, form_class: "w-full sm:w-auto", class: danger_button_class("w-full bg-red-800 hover:bg-red-700"), data: { turbo_confirm: "Are you sure? This is permanent." } %>
    <% end %>
  </div>
</div>
