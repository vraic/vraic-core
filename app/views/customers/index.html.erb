<% content_for :title, "Customers" %>

<div class="w-full">
  
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Customers</h1>
    <%= link_to "New customer", new_customer_path, class: primary_button_class %>
  </div>

  <div class="mt-8">
    <%= form_with url: customers_path, method: :get, class: "flex gap-2" do |f| %>
      <div class="grow">
        <%= f.text_field :query, value: params[:query], placeholder: "Search customers by name, email or phone...", class: input_class %>
      </div>
      <%= f.submit "Search", class: secondary_button_class %>
      <%= link_to "Clear", customers_path, class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" if params[:query].present? %>
    <% end %>
  </div>

  <div class="mt-8 <%= table_container_class %>">
    <table class="<%= table_class %>">
      <thead class="<%= thead_class %>">
        <tr>
          <th class="<%= th_class %>">Customer</th>
          <th class="<%= th_class %>">Type</th>
          <th class="<%= th_class %>">Email</th>
          <th class="<%= th_class %>">Phone</th>
        </tr>
      </thead>
      <tbody class="<%= tbody_class %>" id="customers">
        <% if @customers.any? %>
          <% @customers.each do |customer| %>
            <tr class="<%= tr_class %>">
              <td class="<%= td_class %>">
                <%= link_to customer.name, customer, class: "text-indigo-600 hover:text-indigo-900 font-semibold" %>
              </td>
              <td class="<%= td_class %>">
                <% if customer.customer_account_id.present? %>
                  <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">Business</span>
                <% else %>
                  <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">Individual</span>
                <% end %>
              </td>
              <td class="<%= td_class %>">
                <%= customer.email_address %>
              </td>
              <td class="<%= td_class %>">
                <%= customer.phone %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="<%= td_class %> text-center py-10">No customers found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-8 flex justify-center">
    <%== pagy_tailwind_nav(@pagy) %>
  </div>
</div>
