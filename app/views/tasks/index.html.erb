<% content_for :title, "Tasks" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl text-gray-900 dark:text-white">Tasks</h1>
    <%= link_to "New Task", new_task_path, class: primary_button_class %>
  </div>

  <div class="border-b border-gray-200 dark:border-gray-700 mb-6">
    <nav class="-mb-px flex space-x-8" aria-label="Tabs">
      <%= link_to "Pending", tasks_path, class: "#{@status == 'pending' ? 'border-indigo-500 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <%= link_to "Completed", tasks_path(status: :completed), class: "#{@status == 'completed' ? 'border-indigo-500 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
    </nav>
  </div>

  <%= turbo_stream_from Current.account, "tasks" %>

  <div class="<%= table_container_class %>">
    <table class="<%= table_class %>">
      <thead class="<%= thead_class %>">
        <tr>
          <th scope="col" class="<%= th_class %>">Title</th>
          <th scope="col" class="<%= th_class %>">Responsible</th>
          <th scope="col" class="<%= th_class %>">Assigned By</th>
          <th scope="col" class="<%= th_class %>">Due Date</th>
          <th scope="col" class="<%= th_class %>">Status</th>
          <th scope="col" class="<%= th_class %>">Attachments</th>
          <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody id="tasks" class="<%= tbody_class %>">
        <% if @tasks.any? %>
          <%= render @tasks %>
        <% else %>
          <tr>
            <td colspan="7" class="<%= td_class %> text-center py-10 text-gray-500">No <%= @status %> tasks found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
