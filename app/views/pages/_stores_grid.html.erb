<% 
  v_ids = visible_account_ids
  all_display_accounts = Account.unscoped.where(id: v_ids).to_a
  
  # Sort to put personal accounts first
  personal_ids = ActsAsTenant.without_tenant { Current.user.account_users.pluck(:account_id) }
  all_display_accounts.sort_by! { |a| personal_ids.include?(a.id) ? 0 : 1 }
%>

<% if all_display_accounts.any? %>
  <div id="stores-grid" class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold">Stores</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% all_display_accounts.each do |account| %>
        <% 
          account_user = ActsAsTenant.without_tenant { Current.user.account_users.find_by(account: account) }
          is_personal = account_user.present?
          is_customer = account_user&.customer?
          
          is_joined = is_personal
          
          # Check for business membership (Admin only)
          is_business = false
          if Current.account && Current.user.admin?
            is_business = Customer.unscoped.where(customer_account_id: Current.account.id, account_id: account.id).exists?
          end
          is_joined ||= is_business
          
          is_active = (Current.account == account)
          
          # Border/Bg logic
          if is_customer || is_business
            border_class = "border-green-500 border-2"
            bg_class = "bg-green-50"
          elsif is_active
            border_class = "border-indigo-500 border-2"
            bg_class = "bg-indigo-50"
          else
            border_class = "border-gray-200"
            bg_class = "bg-white"
          end
        %>
        <div class="overflow-hidden rounded-lg <%= bg_class %> shadow border <%= border_class %> dark:bg-gray-800 dark:border-gray-700 flex flex-col">
          <% if account.header_image.attached? %>
            <%= image_tag account.header_image.variant(:card), class: "h-48 w-full object-cover" %>
          <% else %>
            <div class="h-48 w-full bg-gray-100 flex items-center justify-center dark:bg-gray-700">
              <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          <% end %>
          <div class="p-4 flex-grow">
            <div class="flex justify-between items-start">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white"><%= account.name %></h3>
              <div class="flex flex-col items-end gap-1">
                <% if is_customer %>
                  <span class="inline-flex items-center rounded-md bg-green-100 px-2 py-1 text-xs font-medium text-green-700">customer</span>
                <% end %>
                <% if is_business %>
                  <span class="inline-flex items-center rounded-md bg-green-100 px-2 py-1 text-xs font-medium text-green-700">business membership</span>
                <% end %>
                <% if is_personal && !is_customer %>
                  <span class="inline-flex items-center rounded-md bg-blue-100 px-2 py-1 text-xs font-medium text-blue-700">
                    <%= ActsAsTenant.without_tenant { account_user.user_role.titleize } %>
                  </span>
                <% end %>
              </div>
            </div>
            <p class="mt-1 text-sm text-gray-500 line-clamp-2"><%= account.address %></p>
            <% if is_active %>
              <span class="inline-flex items-center rounded-md bg-indigo-100 px-2 py-1 text-xs font-medium text-indigo-700 mt-2">Active</span>
            <% end %>
          </div>
          <div class="p-4 bg-gray-50 border-t border-gray-200 dark:bg-gray-700/50 dark:border-gray-700 flex flex-col gap-2">
            <% if is_personal && !is_customer && !is_active %>
              <%= button_to managed_account_path(account_id: account.id), method: :patch, class: primary_button_class("w-full") do %>
                Manage Store
              <% end %>
            <% end %>
            <%= link_to shop_path(account_id: account.id), class: "w-full inline-flex justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:ring-0 dark:hover:bg-white/20" do %>
              Visit Shop
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="mt-10 p-6 bg-yellow-50 border border-yellow-200 rounded-lg dark:bg-yellow-900/20 dark:border-yellow-900/50">
    <p class="text-yellow-700 dark:text-yellow-400 font-medium">No stores available yet.</p>
  </div>
<% end %>
