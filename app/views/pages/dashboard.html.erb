<% content_for :title, "Dashboard" %>

<div class="w-full">
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Séyiz les beinv'nus</h1>
  </div>

  <div class="mt-10">
    <p class="mb-4">Welcome, <%= Current.user.name %> (<%= Current.user.email_address %>)!</p>
    
    <% if Current.account && (staff? || manager?) %>
      <div id="account-stats" class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-gray-800 dark:ring-1 dark:ring-white/10">
          <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Open Orders</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-indigo-600 dark:text-indigo-400"><%= @open_orders_count %></dd>
          <%= link_to "View orders", orders_path, class: "mt-4 block text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
        </div>

        <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-gray-800 dark:ring-1 dark:ring-white/10">
          <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Supplier Requests</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-indigo-600 dark:text-indigo-400"><%= @pending_supplier_requests_count %></dd>
          <%= link_to "View requests", supplier_requests_path, class: "mt-4 block text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
        </div>

        <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-gray-800 dark:ring-1 dark:ring-white/10">
          <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Open Tasks</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-indigo-600 dark:text-indigo-400"><%= @incomplete_tasks_count %></dd>
          <%= link_to "View tasks", tasks_path, class: "mt-4 block text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
        </div>

        <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-gray-800 dark:ring-1 dark:ring-white/10">
          <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Low Stock Items</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight <%= @low_stock_items_count > 0 ? 'text-red-600 dark:text-red-400' : 'text-indigo-600 dark:text-indigo-400' %>"><%= @low_stock_items_count %></dd>
          <%= link_to "View inventory", inventory_items_path, class: "mt-4 block text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
        </div>
      </div>

      <div id="suppliers-table" class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold">Suppliers</h2>
        </div>
        <% if @suppliers.any? %>
          <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-6">Name</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Email</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white dark:bg-gray-900 dark:divide-gray-800">
                <% @suppliers.each do |supplier| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-white sm:pl-6"><%= supplier.name %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= supplier.email_address %></td>
                    <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                      <% if supplier.supplier_account %>
                        <%= button_to "Visit Shop & Order", managed_account_path(account_id: supplier.supplier_account_id, return_to: new_order_path), method: :patch, class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" %>
                      <% else %>
                        <span class="text-gray-400 italic">No account linked</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-gray-500 dark:text-gray-400">No suppliers found for this store.</p>
        <% end %>
      </div>
      
      <% if Current.user.admin? %>
        <%= render "pages/stores_grid" %>
      <% end %>
    <% else %>
      <% if @customer_orders.any? %>
        <div id="customer-orders" class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
          <h2 class="text-xl font-bold mb-4">My Orders</h2>
          <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-6">Store</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Order #</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Date</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Total</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Status</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                    <span class="sr-only">View</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white dark:bg-gray-900 dark:divide-gray-800">
                <% @customer_orders.each do |order| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-white sm:pl-6"><%= order.account.name %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= order.number %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= order.created_at.strftime("%b %d, %Y") %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400"><%= humanized_money_with_symbol order.total_amount %></td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">
                      <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= order.ordered? ? 'bg-blue-50 text-blue-700 ring-blue-700/10' : order.awaiting_collection? ? 'bg-yellow-50 text-yellow-700 ring-yellow-700/10' : 'bg-green-50 text-green-700 ring-green-700/10' %>">
                        <%= order.status.titleize %>
                      </span>
                    </td>
                    <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                      <%= link_to "View", order_path(order), class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <%= render "pages/stores_grid" %>
    <% end %>
  </div>
</div>
