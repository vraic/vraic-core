<% content_for :title, "Users" %>

<div class="w-full">
  
  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Séyiz les beinv'nus</h1>
    <%= link_to "Create a Store", new_account_path, class: primary_button_class %>
  </div>

  <div class="mt-10">
    <p class="mb-4">Welcome, <%= Current.user.name %> (<%= Current.user.email_address %>)!</p>
    
    <% if Current.user.accounts.any? %>
      <div class="mt-10">
        <h2 class="text-xl font-bold mb-4">Your Stores</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% Current.user.accounts.each do |account| %>
            <div class="p-4 border rounded-lg flex justify-between items-center <%= Current.account == account ? 'bg-indigo-50 border-indigo-200' : 'bg-white border-gray-200' %>">
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white"><%= account.name %></h3>
                <p class="text-sm text-gray-500">
                  Role: <%= Current.user.account_users.find_by(account: account).user_role.titleize %>
                </p>
                <% if Current.account == account %>
                  <span class="inline-flex items-center rounded-md bg-indigo-100 px-2 py-1 text-xs font-medium text-indigo-700 mt-1">Active</span>
                <% end %>
              </div>
              <div>
                <% if Current.account != account %>
                  <%= button_to "Select", managed_account_path(account_id: account.id), method: :patch, class: secondary_button_class("text-xs") %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="mt-10 p-6 bg-yellow-50 border border-yellow-200 rounded-lg dark:bg-yellow-900/20 dark:border-yellow-900/50">
        <p class="text-yellow-700 dark:text-yellow-400 font-medium">No stores joined yet.</p>
        <p class="text-yellow-600 dark:text-yellow-500 mt-1 text-sm">Please select a store below to join, or use a sign-up link from a specific farm shop.</p>
      </div>
    <% end %>

    <% if Current.account && staff? %>
      <div class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
        <h2 class="text-xl font-bold mb-4">Stores joined by <%= Current.account.name %></h2>
        <% 
          joined_customers = Customer.unscoped.where(customer_account_id: Current.account.id).includes(:account)
        %>
        <% if joined_customers.any? %>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Business memberships represent a wholesale relationship for your entire account. 
            Any member of your team can access these stores to place orders and manage the relationship on behalf of <%= Current.account.name %>.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% joined_customers.each do |customer| %>
              <div class="p-4 border rounded-lg flex justify-between items-center <%= Current.account == customer.account ? 'bg-indigo-50 border-indigo-200' : 'bg-white border-gray-200' %>">
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-white"><%= customer.account.name %></h3>
                  <p class="text-sm text-gray-500">Membership type: Business</p>
                  <% if Current.account == customer.account %>
                    <span class="inline-flex items-center rounded-md bg-indigo-100 px-2 py-1 text-xs font-medium text-indigo-700 mt-1">Active</span>
                  <% end %>
                </div>
                <div>
                  <% if Current.account != customer.account %>
                    <%= button_to "Select", managed_account_path(account_id: customer.account.id), method: :patch, class: secondary_button_class("text-xs") %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500 italic">No stores joined yet.</p>
        <% end %>
      </div>
    <% end %>

    <% 
      if Current.user.admin? && Current.account
        joined_account_ids = Customer.unscoped.where(customer_account_id: Current.account.id).pluck(:account_id)
        available_accounts = Account.where.not(id: joined_account_ids).where.not(id: Current.account.id)
      else
        available_accounts = Account.where.not(id: Current.user.account_ids)
      end
    %>

    <% if available_accounts.any? && (!customer? || AccountUser.unscoped.where(user_id: Current.user.id).count <= 1) %>
      <div class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
        <h2 class="text-xl font-bold mb-4">Join a Store</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Associate your account with an available farm shop to start ordering.</p>
        
        <%= form_with url: store_memberships_path, method: :post, class: "flex gap-2 items-end max-w-md" do |f| %>
          <div class="flex-grow">
            <%= f.label :account_id, "Select Store to Join", class: label_class %>
            <%= f.collection_select :account_id, available_accounts, :id, :name, { prompt: "Choose a store..." }, class: input_class %>
          </div>
          <%= f.submit "Join Store", class: primary_button_class %>
        <% end %>
      </div>
    <% end %>

    <% if Current.account && (Current.user.admin? || Current.user.account_users.find_by(account: Current.account)&.store_manager?) %>
      <% 
        supply_available_accounts = Account.where.not(id: Current.account.id)
          .where.not(id: Current.account.customers.pluck(:customer_account_id).compact)
          .where.not(id: SupplierRequest.where(sender_account: Current.account).pluck(:receiver_account_id))
      %>
      <% if supply_available_accounts.any? %>
        <div class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
          <h2 class="text-xl font-bold mb-4">Supply a Store</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Request to become a supplier for another farm shop on the platform using <strong><%= Current.account.name %></strong>.</p>
          
          <%= form_with model: SupplierRequest.new, class: "flex gap-2 items-end max-w-md" do |f| %>
            <div class="flex-grow">
              <%= f.label :receiver_account_id, "Select Store to Supply", class: label_class %>
              <%= f.collection_select :receiver_account_id, supply_available_accounts, :id, :name, { prompt: "Choose a store..." }, class: input_class %>
            </div>
            <%= f.submit "Request to Supply", class: primary_button_class %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <div class="mt-10 border-t border-gray-200 dark:border-gray-700 pt-6">
      <%= button_to "Logout", session_path, method: :delete, class: danger_button_class %>
    </div>
  </div>
</div>