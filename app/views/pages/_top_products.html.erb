<div id="top-products">
  <h2 class="text-xl font-bold mb-4">Frequently Bought</h2>
  <div class="grid grid-cols-2 gap-4">
    <% products.each do |product| %>
      <div class="group relative flex flex-col overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
        <div class="aspect-square bg-gray-200 group-hover:opacity-75 sm:aspect-none sm:h-48">
          <% if product.image.attached? %>
            <%= image_tag product.image, class: "h-full w-full object-cover object-center sm:h-full sm:w-full" %>
          <% else %>
            <div class="h-full w-full flex items-center justify-center bg-gray-100 dark:bg-gray-700 text-gray-400 text-3xl font-bold">
              <%= (product.name || product.display_name || "?")[0] %>
            </div>
          <% end %>
        </div>
        <div class="flex flex-1 flex-col space-y-2 p-4">
          <h3 class="text-sm font-medium text-gray-900 dark:text-white">
            <%= link_to shop_product_path(product) do %>
              <span aria-hidden="true" class="absolute inset-0"></span>
              <%= product.display_name %>
            <% end %>
          </h3>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= product.account.name %></p>
          <div class="flex flex-1 justify-end">
            <p class="text-sm font-bold text-indigo-600"><%= humanized_money_with_symbol product.price %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
