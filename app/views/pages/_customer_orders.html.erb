<div id="customer-orders">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-bold">Recent Orders</h2>
    <%= link_to "View all", orders_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>
  <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700">
    <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
      <% orders.each do |order| %>
        <li class="px-4 py-4 sm:px-6 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
          <%= link_to order_path(order), class: "block" do %>
            <div class="flex items-center justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between sm:justify-start sm:gap-4">
                  <p class="text-sm font-bold text-gray-900 dark:text-white truncate">
                    Order <%= order.number %>
                  </p>
                  <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= order.ordered? ? 'bg-blue-50 text-blue-700 ring-blue-700/10' : order.awaiting_collection? ? 'bg-yellow-50 text-yellow-700 ring-yellow-700/10' : 'bg-green-50 text-green-700 ring-green-700/10' %>">
                    <%= order.status.titleize %>
                  </span>
                </div>
                <div class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-400">
                  <span class="truncate"><%= order.account.name %></span>
                  <span class="mx-1">&middot;</span>
                  <span><%= order.created_at.strftime("%b %d, %Y") %></span>
                </div>
              </div>
              <div class="ml-4 flex-shrink-0 text-right">
                <p class="text-sm font-bold text-gray-900 dark:text-white">
                  <%= humanized_money_with_symbol order.total_amount %>
                </p>
                <div class="mt-2 text-indigo-600 dark:text-indigo-400 text-sm font-medium">
                  View details &rarr;
                </div>
              </div>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
