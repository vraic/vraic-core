<div id="<%= dom_id inventory_level %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Inventory item:</strong>
    <%= inventory_level.inventory_item.display_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Location:</strong>
    <%= inventory_level.location.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Quantity:</strong>
    <%= pluralize(inventory_level.quantity, inventory_level.inventory_item.stock_unit) %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Account:</strong>
    <%= inventory_level.account_id %>
  </div>
</div>
