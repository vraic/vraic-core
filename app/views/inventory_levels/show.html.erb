<% content_for :title, "Showing inventory level" %>

<div class="md:w-2/3 w-full">
  
  <h1 class="font-bold text-4xl">Showing inventory level</h1>

  <%= render @inventory_level %>

  <div class="flex flex-wrap gap-2 mt-4">
    <%= link_to "Edit this inventory level", edit_inventory_level_path(@inventory_level), class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= link_to "Back to inventory levels", inventory_levels_path, class: secondary_button_class("w-full sm:w-auto text-center") %>
    <%= button_to "Destroy this inventory level", @inventory_level, method: :delete, form_class: "w-full sm:w-auto", class: danger_button_class("w-full"), data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
