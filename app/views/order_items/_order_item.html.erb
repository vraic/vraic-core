<div id="<%= dom_id order_item %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Order:</strong>
    <%= order_item.order_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Inventory item:</strong>
    <%= order_item.inventory_item_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Quantity:</strong>
    <%= order_item.quantity %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price cents:</strong>
    <%= order_item.price_cents %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Currency:</strong>
    <%= order_item.currency %>
  </div>
</div>
