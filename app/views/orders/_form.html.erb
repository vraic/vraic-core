<%= form_with(model: order, class: "contents") do |form| %>
  <% if order.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(order.errors.count, "error") %> prohibited this order from being saved:</h2>
      <ul class="list-disc ml-6">
        <% order.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-5" 
       data-controller="loyalty-redemption" 
       data-loyalty-redemption-customers-value="<%= @customers_data&.to_json %>"
       data-loyalty-redemption-ratio-value="<%= @loyalty_program&.points_to_currency_ratio %>">
    
    <% if staff? %>
      <div>
        <%= form.label :customer_id, class: label_class %>
        <%= form.collection_select :customer_id, policy_scope(Customer).order(:name), :id, :name, { prompt: "Select Customer" }, 
            class: input_class, data: { loyalty_redemption_target: "customerSelect", action: "change->loyalty-redemption#updateBalance" } %>
      </div>

      <div>
        <%= form.label :status, class: label_class %>
        <%= form.select :status, Order.statuses.keys.map { |s| [s.titleize, s] }, {}, class: input_class %>
      </div>
    <% else %>
      <% customer = Customer.find_by(user: Current.user, account: Current.account) %>
      <% if customer %>
        <input type="hidden" data-loyalty-redemption-target="customerSelect" value="<%= customer.id %>">
      <% end %>
    <% end %>

    <% if @loyalty_program&.active? %>
      <div id="loyalty-redemption-fields" class="col-span-1 md:col-span-2 bg-indigo-50 dark:bg-indigo-900/20 p-4 rounded-lg hidden" data-loyalty-redemption-target="container">
        <h4 class="text-sm font-bold text-indigo-900 dark:text-indigo-300 mb-2 uppercase tracking-wide">Loyalty Redemption</h4>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <div class="w-full sm:w-1/3">
            <span class="text-sm text-indigo-700 dark:text-indigo-400" data-loyalty-redemption-target="balanceDisplay"></span>
          </div>
          <div class="w-full sm:w-1/3">
            <%= form.label :loyalty_points_redeemed, "Points to redeem", class: "sr-only" %>
            <%= form.number_field :loyalty_points_redeemed, min: 0, class: input_class, 
                data: { loyalty_redemption_target: "redeemInput", action: "input->loyalty-redemption#updateDiscount" }, placeholder: "Points to redeem" %>
          </div>
          <div class="w-full sm:w-1/3 text-right">
            <span class="text-lg font-bold text-indigo-600 dark:text-indigo-400" data-loyalty-redemption-target="discountDisplay"></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="my-5">
    <%= form.label :notes, class: label_class %>
    <%= form.text_area :notes, rows: 3, class: input_class %>
  </div>

  <div class="my-5">
    <%= form.label :location_id, "Collection point", class: label_class %>
    <%= form.collection_select :location_id, Location.where(collection_point: true), :id, :name, { prompt: "Select Collection Point" }, class: input_class, required: !staff? %>
  </div>

  <div class="my-5">
    <%= form.label :payment_method, "Payment method", class: label_class %>
    <%= form.select :payment_method,
                    [["Cash on collection", "cash_on_collection"], ["GoCardless", "gocardless"]],
                    { selected: params.dig(:order, :payment_method).presence || "cash_on_collection" },
                    class: input_class %>

    <% if customer? %>
      <% customer = Customer.find_by(user: Current.user, account: Current.account) %>
      <% unless customer&.gocardless_configured? %>
        <p class="text-sm text-gray-600 mt-2">To use GoCardless, complete one-time setup first.</p>
        <%= button_to "Set up GoCardless", customer_gocardless_setup_path,
                      method: :post,
                      params: { setup: { bank_account_token: "#{customer&.id}-setup" } },
                      class: secondary_button_class %>
      <% end %>
    <% end %>
  </div>

  <div class="my-10" data-controller="nested-form">
    <template data-nested-form-target="template">
      <%= form.fields_for :order_items, OrderItem.new, child_index: "NEW_RECORD" do |item_form| %>
        <%= render "order_item_fields", f: item_form %>
      <% end %>
    </template>

    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-bold">Order Items</h3>
      <button type="button" data-action="nested-form#add" class="<%= secondary_button_class %>">
        Add Item
      </button>
    </div>

    <div data-nested-form-target="container">
      <%= form.fields_for :order_items do |item_form| %>
        <%= render "order_item_fields", f: item_form %>
      <% end %>
    </div>
  </div>

  <div class="inline">
    <%= form.submit class: primary_button_class %>
  </div>
<% end %>
