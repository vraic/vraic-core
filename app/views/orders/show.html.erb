<div class="bg-gray-50 dark:bg-gray-900 min-h-screen">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl">Order #<%= @order.number %></h1>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
          Placed on <%= @order.created_at.strftime("%B %d, %Y") %> &bull; <%= @order.account.name %>
        </p>
      </div>
      <div class="flex gap-2">
        <% if policy(@order).edit? %>
          <%= link_to "Edit", edit_order_path(@order), class: secondary_button_class %>
        <% end %>
        <%= link_to "Back to Orders", orders_path, class: secondary_button_class %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Left Column: Items and Status -->
      <div class="lg:col-span-8 space-y-6">
        <!-- Status Card -->
        <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg border border-gray-200 dark:border-gray-700 p-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <div>
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</h3>
              <p class="text-lg font-bold text-gray-900 dark:text-white"><%= @order.status.titleize %></p>
            </div>
            <div class="text-left sm:text-right">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Collection Point</h3>
              <p class="text-base font-semibold text-indigo-600"><%= @order.location&.name || "TBD" %></p>
            </div>
          </div>

          <div class="relative mt-8">
            <div class="overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
              <% progress = { "ordered" => "33%", "awaiting_collection" => "66%", "complete" => "100%" }[@order.status] %>
              <div style="width: <%= progress %>" class="h-2 rounded-full bg-indigo-600 transition-all duration-500"></div>
            </div>
            <div class="mt-4 grid grid-cols-3 text-xs font-medium text-gray-500 dark:text-gray-400">
              <div class="<%= 'text-indigo-600 font-bold' if @order.ordered? %>">Ordered</div>
              <div class="text-center <%= 'text-indigo-600 font-bold' if @order.awaiting_collection? %>">Ready for Collection</div>
              <div class="text-right <%= 'text-indigo-600 font-bold' if @order.complete? %>">Collected</div>
            </div>
          </div>
        </div>

        <!-- Items Card -->
        <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">Items</h2>
          </div>
          <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @order.order_items.each do |item| %>
              <li class="p-4 sm:px-6 flex items-center gap-4">
                <div class="size-16 shrink-0 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                  <% if item.inventory_item.image.attached? %>
                    <%= image_tag item.inventory_item.image, class: "size-full object-cover" %>
                  <% else %>
                    <span class="text-gray-400 text-xl font-bold"><%= item.inventory_item.name&.chr %></span>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <h4 class="text-sm font-bold text-gray-900 dark:text-white">
                    <%= link_to item.inventory_item.display_name, shop_product_path(item.inventory_item), class: "hover:text-indigo-600" %>
                  </h4>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= humanized_money_with_symbol item.price %> per unit</p>
                </div>
                <div class="text-right">
                  <p class="text-sm font-medium text-gray-900 dark:text-white">Qty <%= item.quantity %></p>
                  <p class="text-sm font-bold text-indigo-600"><%= humanized_money_with_symbol item.total_price %></p>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Right Column: Summary & Management -->
      <div class="lg:col-span-4 space-y-6">
        <!-- Billing/Customer Card -->
        <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg border border-gray-200 dark:border-gray-700 p-6">
          <div class="space-y-6">
            <div>
              <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Customer</h3>
              <p class="text-sm font-bold text-gray-900 dark:text-white"><%= @order.customer.name %></p>
              <p class="text-sm text-gray-500"><%= @order.customer.email_address %></p>
              <%= link_to "View Customer Details", @order.customer, class: "text-xs text-indigo-600 hover:underline mt-2 inline-block" if staff? %>
            </div>
            
            <div class="pt-6 border-t border-gray-100 dark:border-gray-700">
              <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Payment</h3>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-900 dark:text-white font-medium"><%= @order.payment&.payment_method&.titleize || "TBD" %></span>
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= @order.payment&.status == 'paid' ? 'bg-green-50 text-green-700 ring-green-600/20' : 'bg-yellow-50 text-yellow-700 ring-yellow-600/20' %>">
                  <%= @order.payment&.status&.titleize || "Pending" %>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Totals Card -->
        <div class="bg-indigo-600 rounded-lg shadow-lg p-6 text-white">
          <dl class="space-y-3">
            <div class="flex justify-between text-sm opacity-90">
              <dt>Subtotal</dt>
              <dd><%= humanized_money_with_symbol(@order.total_amount + @order.loyalty_discount) %></dd>
            </div>
            <% if @order.loyalty_discount_amount_cents > 0 %>
              <div class="flex justify-between text-sm font-medium text-green-200">
                <dt>Loyalty Discount</dt>
                <dd>- <%= humanized_money_with_symbol @order.loyalty_discount %></dd>
              </div>
            <% end %>
            <div class="flex justify-between pt-3 border-t border-white/20">
              <dt class="text-lg font-bold">Total</dt>
              <dd class="text-lg font-bold"><%= humanized_money_with_symbol @order.total_amount %></dd>
            </div>
          </dl>
        </div>

        <!-- Staff Management -->
        <% if staff? %>
          <div class="bg-white dark:bg-gray-800 shadow sm:rounded-lg border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Staff Actions</h2>
            
            <% unless @order.complete? %>
              <div class="grid grid-cols-1 gap-3 mb-6">
                <% if @order.ordered? %>
                  <%= button_to "Mark as Ready", awaiting_collection_order_path(@order), method: :patch, class: primary_button_class %>
                <% elsif @order.awaiting_collection? %>
                  <%= button_to "Mark as Collected", complete_order_path(@order), method: :patch, class: primary_button_class %>
                <% end %>
              </div>
            <% end %>

            <h3 class="text-xs font-bold text-gray-400 uppercase mb-3">Notes</h3>
            <div class="space-y-4 max-h-60 overflow-y-auto mb-4 pr-2">
              <% @order.staff_notes.includes(:user).order(created_at: :asc).each do |note| %>
                <div class="text-sm bg-gray-50 dark:bg-gray-900/50 p-3 rounded-lg">
                  <div class="flex justify-between mb-1 opacity-60 text-[10px] font-bold">
                    <span><%= note.user.name %></span>
                    <span><%= note.created_at.strftime("%b %d, %H:%M") %></span>
                  </div>
                  <p class="text-gray-700 dark:text-gray-300"><%= note.content %></p>
                </div>
              <% end %>
            </div>

            <%= form_with model: [ @order, Note.new ] do |f| %>
              <%= f.text_area :content, rows: 2, class: input_class(false, "text-sm h-auto"), placeholder: "Add staff note..." %>
              <div class="mt-2">
                <%= f.submit "Save Note", class: secondary_button_class("w-full") %>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Danger Zone -->
        <% if policy(@order).destroy? %>
          <div class="bg-red-50 dark:bg-red-900/10 rounded-lg p-4 border border-red-200 dark:border-red-900/20 text-center">
            <%= button_to "Cancel/Delete Order", @order, method: :delete, class: "text-xs font-bold text-red-600 hover:text-red-700 dark:text-red-400", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
