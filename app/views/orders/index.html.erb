<% content_for :title, "Orders" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">Orders</h1>
    <%= link_to "New Order", new_order_path, class: primary_button_class %>
  </div>

  <div class="mb-6">
    <%= form_with url: orders_path, method: :get, class: "flex gap-2" do |f| %>
      <div class="grow">
        <%= f.text_field :query, value: params[:query], placeholder: "Search by ID, customer name or total...", class: input_class %>
      </div>
      <%= f.submit "Search", class: secondary_button_class %>
      <%= link_to "Clear", orders_path, class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" if params[:query].present? || params[:filter].present? %>
    <% end %>
  </div>

  <div class="<%= table_container_class %>">
    <table class="<%= table_class %>">
      <thead class="<%= thead_class %>">
        <tr>
          <% if Current.account.nil? && Current.user&.admin? %>
            <th class="<%= th_class %>">Account</th>
          <% end %>
          <th class="<%= th_class %>">Order Date</th>
          <th class="<%= th_class %>">Order ID</th>
          <th class="<%= th_class %>">Customer Name</th>
          <th class="<%= th_class %>">Total</th>
          <th class="<%= th_class %>">Status</th>
        </tr>
      </thead>
      <tbody class="<%= tbody_class %>">
        <% if @orders.any? %>
          <% @orders.each do |order| %>
            <tr class="<%= tr_class %>">
              <% if Current.account.nil? && Current.user&.admin? %>
                <td class="<%= td_class %> font-semibold">
                  <%= order.account.name %>
                </td>
              <% end %>
              <td class="<%= td_class %> font-medium text-indigo-600">
                <%= link_to order.created_at.strftime("%b %d, %Y %H:%M"), order %>
              </td>
              <td class="<%= td_class %> font-medium text-indigo-600">
                <%= link_to order.number, order %>
              </td>
              <td class="<%= td_class %>">
                <%= order.customer.name %>
              </td>
              <td class="<%= td_class %>">
                <%= order.total_amount.format %>
              </td>
              <td class="<%= td_class %>">
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset <%= 
                  case order.status
                  when 'ordered' then 'bg-yellow-50 text-yellow-800 ring-yellow-600/20'
                  when 'awaiting_collection' then 'bg-blue-50 text-blue-800 ring-blue-600/20'
                  when 'complete' then 'bg-green-50 text-green-800 ring-green-600/20'
                  end %>">
                  <%= order.status.titleize %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="<%= td_class %> text-center py-10 text-gray-500">No orders found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-8 flex justify-center">
    <%== pagy_tailwind_nav(@pagy) %>
  </div>
</div>
