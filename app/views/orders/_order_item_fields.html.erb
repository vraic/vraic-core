<div class="nested-form-wrapper grid grid-cols-1 md:grid-cols-5 gap-4 items-end border-b border-gray-100 dark:border-gray-800 pb-4 mb-4" 
     data-controller="order-item" 
     data-new-record="<%= f.object.new_record? %>">
  <div class="md:col-span-2">
    <%= f.label :inventory_item_id, "Product", class: label_class %>
    <%= f.select :inventory_item_id, 
        options_for_select(policy_scope(InventoryItem).order(:name).map { |i| [i.display_name, i.id, { 'data-stock-data': i.stock_data.to_json }] }, f.object.inventory_item_id),
        { prompt: "Select Product" }, 
        class: input_class,
        data: { order_item_target: "itemSelect", action: "change->order-item#updateItem" } %>
  </div>

  <div class="<%= 'hidden' unless staff? %>">
    <%= f.label :location_id, "Location", class: label_class %>
    <% 
      locations = policy_scope(Location).order(:name)
    %>
    <%= f.collection_select :location_id, locations, :id, :name, 
        { prompt: "Select Location" }, 
        class: input_class,
        required: staff?,
        data: { order_item_target: "locationSelect", action: "change->order-item#updateLocation" } %>
  </div>

  <div>
    <%= f.label :quantity, class: label_class %>
    <%= f.number_field :quantity, min: 1, class: input_class,
        data: { order_item_target: "quantityInput" } %>
  </div>

  <div class="flex items-center gap-2">
    <div class="flex-1">
      <%= f.label :price, "Unit Price", class: label_class %>
      <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
          <span class="text-gray-500 sm:text-sm">£</span>
        </div>
        <% if staff? %>
          <%= f.text_field :price, value: f.object.price, class: "#{input_class} pl-7", placeholder: "0.00",
              data: { order_item_target: "priceInput" } %>
        <% else %>
          <div class="<%= input_class %> pl-7 bg-gray-50 dark:bg-gray-800/50 flex items-center">
            <span data-order-item-target="priceDisplay"><%= number_to_currency(f.object.price, unit: "") %></span>
          </div>
          <%= f.hidden_field :price, data: { order_item_target: "priceInput" } %>
        <% end %>
      </div>
    </div>
    
    <%= f.hidden_field :_destroy %>
    <button type="button" data-action="nested-form#remove" class="<%= danger_button_class %> p-2 mt-6">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
      </svg>
    </button>
  </div>
</div>
