<% content_for :title, "Choose how to secure your account" %>

<div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">How would you like to sign in?</h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
    You’ve signed in with a one-time email code. Choose your preferred sign-in method.
  </p>

  <div class="mt-8 grid gap-4">
    <%= form_with url: security_setup_path, method: :post, class: "rounded-lg border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-gray-800" do |f| %>
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Configure a secure password</h2>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Recommended for faster sign-ins and stronger account protection.</p>
      <%= f.hidden_field :choice, value: "password" %>
      <%= f.submit "Set up a secure password", class: "mt-4 rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400" %>
    <% end %>

    <%= form_with url: security_setup_path, method: :post, class: "rounded-lg border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-gray-800" do |f| %>
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Always login using a code via email</h2>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">We’ll continue sending one-time codes to your email whenever you sign in.</p>
      <%= f.hidden_field :choice, value: "email_login" %>
      <%= f.submit "Continue with email codes", class: secondary_button_class("mt-4") %>
    <% end %>
  </div>
</div>