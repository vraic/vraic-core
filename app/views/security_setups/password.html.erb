<% content_for :title, "Set a secure password" %>
<% content_for :no_sidebar, true %>

<div class="mx-auto max-w-xl px-4 py-12 sm:px-6 lg:px-8">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Set a secure password</h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Create a strong password to improve your account security.</p>

  <%= form_with model: @user, url: update_password_security_setup_path, method: :patch, class: "mt-8 space-y-6" do |f| %>
    <div>
      <%= f.label :password, "New password", class: label_class %>
      <div class="mt-2">
        <%= f.password_field :password, autocomplete: "new-password", required: true, class: input_class %>
      </div>
      <% @user.errors.full_messages_for(:password).each do |message| %>
        <p class="mt-2 text-sm text-red-600 dark:text-red-400"><%= message %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", class: label_class %>
      <div class="mt-2">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: input_class %>
      </div>
    </div>

    <%= f.submit "Save secure password", class: primary_button_class("w-full justify-center") %>
  <% end %>
</div>