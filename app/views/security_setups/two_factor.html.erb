<% content_for :title, "Add two-factor authentication" %>
<% content_for :no_sidebar, true %>

<div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Configure 2-factor authentication</h1>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
    This is optional, but highly recommended for added security.
  </p>

  <div class="mt-8 rounded-lg border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-gray-800">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Add an authenticator app so your account stays protected even if your password is compromised.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to "Configure 2FA", two_factor_auth_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400" %>
      <%= link_to "Skip for now", onboarding_path, class: secondary_button_class %>
    </div>
  </div>
</div>