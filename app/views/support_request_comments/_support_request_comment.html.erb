<div id="<%= dom_id comment %>" class="flex <%= comment.user.admin? ? 'justify-end' : 'justify-start' %>" data-controller="comment">
  <div class="max-w-[80%] rounded-lg px-4 py-2 shadow-sm border <%= comment.user.admin? ? 'bg-indigo-50 border-indigo-100 dark:bg-indigo-900/20 dark:border-indigo-800' : 'bg-white border-gray-200 dark:bg-gray-800 dark:border-gray-700' %>">
    <div class="flex justify-between items-center mb-1 space-x-4">
      <span class="text-xs font-bold <%= comment.user.admin? ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-400' %>">
        <%= comment.user.name %> <%= '(Support Staff)' if comment.user.admin? %>
      </span>
      <span class="text-[10px] text-gray-400"><%= comment.created_at.to_fs(:short) %></span>
    </div>

    <div data-comment-target="body" class="text-sm text-gray-900 dark:text-white whitespace-pre-wrap"><%= comment.body %></div>

    <% if policy(comment).update? %>
      <div class="mt-2 text-right">
        <button type="button" class="text-[10px] text-gray-400 hover:text-indigo-600" data-action="click->comment#toggle">Edit</button>
      </div>

      <div data-comment-target="form" class="hidden mt-2">
        <%= form_with(model: [comment.support_request, comment], url: support_request_comment_path(comment.support_request, comment), local: true) do |f| %>
          <%= f.text_area :body, rows: 3, class: input_class %>
          <div class="mt-2 flex justify-end space-x-2">
            <button type="button" class="text-xs text-gray-500" data-action="click->comment#toggle">Cancel</button>
            <%= f.submit "Save", class: "text-xs font-semibold text-indigo-600 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
